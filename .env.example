# ===================================
# Dashboard Performance 2026 - Configuration
# ===================================
# Copiez ce fichier vers .env.local et remplissez les valeurs

# ----------------------------------
# Google Analytics 4
# ----------------------------------
# Property ID GA4 (Admin > Property Settings)
# Format: 123456789 (juste le nombre)
GA4_PROPERTY_ID=

# ----------------------------------
# Google Search Console
# ----------------------------------
# URL du site dans GSC
# Format: https://www.example.com ou sc-domain:example.com
GSC_SITE_URL=

# Nom de marque pour filtrer le trafic Branded
# Ex: "MonEntreprise" - utilisé pour les requêtes contenant ce mot
BRAND_NAME=

# ----------------------------------
# PageSpeed Insights
# ----------------------------------
# URL du site à analyser (optionnel, utilise GSC_SITE_URL par défaut)
SITE_URL_FOR_PAGESPEED=

# Clé API PageSpeed (optionnel mais recommandé pour éviter les limites)
# Obtenir sur: https://console.cloud.google.com/apis/credentials
PAGESPEED_API_KEY=

# ----------------------------------
# Authentification Google (Service Account)
# ----------------------------------
# Chemin vers le fichier JSON du Service Account
# Téléchargé depuis Google Cloud Console
# Ce service account doit avoir accès à GA4 et GSC
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/credentials.json

# ----------------------------------
# Dashboard
# ----------------------------------
# Mot de passe pour accéder au dashboard (défaut: kpi2026)
DASHBOARD_PASSWORD=kpi2026
