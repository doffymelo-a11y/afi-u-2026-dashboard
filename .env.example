# Google Analytics 4 Configuration
# ================================

# Property ID GA4 (trouvable dans Admin > Property Settings)
# Format: 123456789 (juste le nombre, sans "properties/")
GA4_PROPERTY_ID=

# Chemin vers le fichier de credentials du Service Account
# Téléchargé depuis Google Cloud Console
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/credentials.json

# Mot de passe du dashboard (optionnel, défaut: kpi2026)
DASHBOARD_PASSWORD=kpi2026
